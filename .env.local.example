# ──────────────────────────────────────────────────────────────
# Go HighLevel (GHL) — Lead capture
# ──────────────────────────────────────────────────────────────
# The website lead form posts to /api/quote (server proxy), which forwards to
# this webhook. Prefer the SERVER-SIDE variable (no NEXT_PUBLIC_ prefix) so the
# webhook URL is never exposed in the browser.
# Get it from: GHL Settings → Integrations → Webhooks → Create Webhook
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID

# Calendar booking widget URL — powers the "Book a Call" modal in the navbar.
# Get it from: GHL Settings → Calendars → [Your Calendar] → Booking Widget URL
NEXT_PUBLIC_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/YOUR_CALENDAR_ID

# ──────────────────────────────────────────────────────────────
# Analytics (optional — events are safe no-ops until one is set)
# ──────────────────────────────────────────────────────────────
# Preferred: a Google Tag Manager container (manage GA4 + all tags inside GTM).
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Optional: a direct GA4 Measurement ID (only if you are NOT using GTM).
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
