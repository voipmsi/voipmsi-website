# Go HighLevel Integration
# Replace with your actual GHL inbound webhook URL from:
# GHL Settings → Integrations → Webhooks → Create Webhook
NEXT_PUBLIC_GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID

# Replace with your actual GHL calendar booking URL from:
# GHL Settings → Calendars → [Your Calendar] → Booking Widget URL
NEXT_PUBLIC_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/YOUR_CALENDAR_ID
